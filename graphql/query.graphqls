type Query {

    players: MineplexPlayersData

    games: [MineplexGame]
    gameById(id: ID!): MineplexGame

    accounts(page: Int!, perPage: Int!): [MineplexAccount]
    accountById(id: Int!): MineplexAccount

    forums(page: Int!, perPage: Int!): [MineplexForum]
    forumsByCreator(creatorId: Int!): [MineplexForum]
    forumById(id: String!): MineplexForum

    sendForumMessage(token: String!, forumId: ID!, content: String!): OkReplay


}